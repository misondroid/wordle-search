{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wordle-search-backend",
  "main": "src/index.js",
  "compatibility_date": "2026-05-30",
  "triggers": {
    "crons": ["0 10 * * *"]
  },
  "r2_buckets": [
    {
      "binding": "ANSWERS_BUCKET",
      "bucket_name": "word-search"
    }
  ],
  "vars": {
    "ANSWERS_KEY": "answers.json",
    "WORDLE_TIME_ZONE": "America/New_York"
  }
}
